{
  "name": "koishi-plugin-mcsm-portal-pro",
  "description": "A personal customized fork of KrLite/mcsm-portal for Koishi.",
  "version": "0.0.27",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "homepage": "https://github.com/KlN-4096/mcsm-portal-pro",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KlN-4096/mcsm-portal-pro.git"
  },
  "bugs": {
    "url": "https://github.com/KlN-4096/mcsm-portal-pro/issues"
  },
  "files": [
    "lib",
    "dist",
    "assets"
  ],
  "license": "MIT",
  "scripts": {
    "build": "node scripts/clean-server-build.mjs && tsc -p tsconfig.json && tsc -p tsconfig.client.json && node scripts/build-client.mjs",
    "build:client": "tsc -p tsconfig.client.json && node scripts/build-client.mjs",
    "prepack": "npm run build",
    "build:visualization": "tailwindcss -c tailwind.config.cjs -i assets/visualization/layout.tailwind.css -o assets/visualization/layout.css --minify"
  },
  "keywords": [
    "chatbot",
    "koishi",
    "plugin"
  ],
  "devDependencies": {
    "@koishijs/client": "^5.30.4",
    "@types/node": "^22.17.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "esbuild": "^0.25.12",
    "koishi": "^4.18.7",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.3",
    "yml-register": "^1.2.5"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "koishi": {
    "public": [
      "dist"
    ],
    "description": {
      "en": "A personal customized MCSManager portal based on KrLite/mcsm-portal.",
      "zh": "基于 KrLite/mcsm-portal 的自用Minecraft客制化 MCSManager 状态入口。"
    },
    "service": {
      "optional": [
        "console",
        "puppeteer"
      ]
    }
  },
  "peerDependencies": {
    "@koishijs/plugin-console": "^5.30.4",
    "koishi": "^4.18.7"
  },
  "peerDependenciesMeta": {
    "@koishijs/plugin-console": {
      "optional": true
    }
  }
}
